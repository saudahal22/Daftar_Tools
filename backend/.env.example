# ==================================
# Server
# ==================================
PORT=3001

# ==================================
# MongoDB
# ==================================
MONGO_URI=mongodb://admin:password123@localhost:27017/katalog-tools?authSource=admin

# ==================================
# MinIO
# ==================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tool-icons
MINIO_USE_SSL=false

# ==================================
# RapidAPI (Data Ingestion) — Opsional
# ==================================
RAPIDAPI_KEY=your-rapidapi-key-here
RAPIDAPI_HOST=your-rapidapi-host-here
RAPIDAPI_URL=https://your-rapidapi-endpoint-here

# ==================================
# GitHub Token (Data Crawling) — Opsional tapi SANGAT DIREKOMENDASIKAN
# Tanpa token: rate limit 10 req/menit (unauthenticated)
# Dengan token: rate limit 30 req/menit (authenticated)
# Buat token di: https://github.com/settings/tokens
# Scopes yang diperlukan: public_repo (read-only)
# ==================================
GITHUB_TOKEN=your-github-token-here

# ==================================
# Frontend URL (CORS)
# ==================================
FRONTEND_URL=http://localhost:3000
